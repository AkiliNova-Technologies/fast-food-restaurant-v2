generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  staff
}

enum PaymentMethod {
  cash_on_delivery
  mobile_money
}

enum MobileMoneyProvider {
  mtn
  airtel
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum OrderStatus {
  pending
  accepted
  preparing
  completed
  cancelled
}

enum ContactMessageStatus {
  new
  read
  resolved
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  email     String   @unique @db.VarChar(180)
  password  String   @db.VarChar(255)
  role      UserRole @default(admin)
  createdAt DateTime @default(now()) @map("created_at")

  authTokens AuthToken[]

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(160)
  description String?
  image       String?  @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@index([isActive])
  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int?     @map("category_id")
  name        String   @db.VarChar(180)
  slug        String   @unique @db.VarChar(220)
  description String?
  price       Decimal  @default(0.00) @db.Decimal(10, 2)
  oldPrice    Decimal? @map("old_price") @db.Decimal(10, 2)
  image       String?  @db.VarChar(255)
  badge       String?  @db.VarChar(80)
  rating      Decimal  @default(5.0) @db.Decimal(2, 1)
  isFeatured  Boolean  @default(false) @map("is_featured")
  isPopular   Boolean  @default(false) @map("is_popular")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isPopular])
  @@index([isAvailable])
  @@map("products")
}

model Offer {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(180)
  slug            String    @unique @db.VarChar(220)
  description     String?
  discountPercent Int       @default(0) @map("discount_percent")
  image           String?   @db.VarChar(255)
  startsAt        DateTime? @map("starts_at")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([isActive])
  @@map("offers")
}

model Order {
  id              Int     @id @default(autoincrement())
  customerName    String  @map("customer_name") @db.VarChar(150)
  phone           String  @db.VarChar(50)
  email           String? @db.VarChar(180)
  deliveryAddress String? @map("delivery_address")
  totalAmount     Decimal @default(0.00) @map("total_amount") @db.Decimal(10, 2)

  paymentMethod       PaymentMethod        @default(cash_on_delivery) @map("payment_method")
  mobileMoneyProvider MobileMoneyProvider? @map("mobile_money_provider")
  paymentPhone        String?              @map("payment_phone") @db.VarChar(50)
  paymentStatus       PaymentStatus        @default(pending) @map("payment_status")
  receiptNumber       String?              @unique @map("receipt_number") @db.VarChar(80)

  status    OrderStatus @default(pending)
  notes     String?
  createdAt DateTime    @default(now()) @map("created_at")

  items OrderItem[]

  @@index([status])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([receiptNumber])
  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  productId   Int?    @map("product_id")
  productName String  @map("product_name") @db.VarChar(180)
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0.00) @map("unit_price") @db.Decimal(10, 2)
  lineTotal   Decimal @default(0.00) @map("line_total") @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model ContactMessage {
  id        Int                  @id @default(autoincrement())
  name      String               @db.VarChar(150)
  email     String?              @db.VarChar(180)
  phone     String?              @db.VarChar(50)
  subject   String?              @db.VarChar(180)
  message   String
  status    ContactMessageStatus @default(new)
  createdAt DateTime             @default(now()) @map("created_at")

  @@index([status])
  @@map("contact_messages")
}

model AuthToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model SiteVisit {
  id        Int      @id @default(autoincrement())
  path      String?  @db.VarChar(255)
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("site_visits")
}
